
aws_region = "eu-central-1"

# EKS Cluster Configuration
cluster_name    = "microservices-cluster"
cluster_version = "1.31"
environment     = "production"

# VPC Configuration
vpc_cidr = "10.0.0.0/16"

# Node Pool Configuration
# For AWS Free Tier: use t3.micro or t2.micro
# For production: use t3.medium or larger
node_instance_type = "t3.micro"  # Free Tier eligible
node_desired_size  = 2           # Reduced for Free Tier (costs: 3x t3.micro ~$6/month)
node_min_size      = 1           # Minimum 1 node
node_max_size      = 3           # Maximum 3 nodes for Free Tier budget

# CloudWatch Logging
log_retention_days = 7  # Reduced for Free Tier cost savings (30 days = ~$15/month)

# Tagging
tags = {
  Project     = "Microservices"
  ManagedBy   = "Terraform"
  Owner       = "Mohamed Fayad"
  CostCenter  = "Engineering"
  Environment = "production"
  BillingAlarm = "true"
}
